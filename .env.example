# --- Backend selection ---
# Which inference backend the agent talks to: pontoon | ironwood | wsl
LOON_BACKEND=wsl

# Optional per-backend overrides (defaults live in src/loon_agent/config.py).
# LOON_PONTOON_BASE_URL=http://pontoon.lan:1234/v1
# LOON_PONTOON_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
# LOON_IRONWOOD_BASE_URL=http://ironwood.lan:8000/v1
# LOON_IRONWOOD_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
# LOON_WSL_BASE_URL=http://localhost:8000/v1
# LOON_WSL_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ

# Sampling
LOON_TEMPERATURE=0

# Where conversation state (checkpointer) and long-term memory live
LOON_DATA_DIR=.loon

# --- Telegram adapter (python -m loon_agent telegram) ---
# Token from @BotFather.
# LOON_TELEGRAM_TOKEN=123456789:AA...
# Comma-separated numeric Telegram user ids allowed to talk to the bot.
# Empty = deny everyone; DM the bot once and it replies with your id.
# LOON_TELEGRAM_ALLOWED_USERS=123456789

# --- OpenTelemetry (optional; unset = no-op, set console to print spans) ---
# LOON_OTEL=console            # off | console | otlp
# OTEL_SERVICE_NAME=loon-agent
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
