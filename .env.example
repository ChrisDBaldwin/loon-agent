# --- Backends ---
# Any LOON_<NAME>_BASE_URL defines a backend named <name>; LOON_BACKEND picks one.
# The built-in "local" backend points at http://localhost:1234/v1 (LM Studio's
# default port) — you only need to tell loon which model your server is serving.
LOON_BACKEND=local
LOON_LOCAL_MODEL=qwen2.5-7b-instruct
# LOON_LOCAL_BASE_URL=http://localhost:1234/v1
# LOON_LOCAL_API_KEY=...       # only if your server enforces token auth

# Add more boxes the same way (works with vLLM, Ollama, llama.cpp server, ...):
# LOON_GPUBOX_BASE_URL=http://gpubox.lan:8000/v1
# LOON_GPUBOX_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# Sampling
LOON_TEMPERATURE=0

# Where conversation state (checkpointer) and long-term memory live
LOON_DATA_DIR=.loon

# Long-term memory backend: sqlite (FTS5 keyword recall, default, no extra deps) or
# chroma (local embeddings + nearest-neighbor recall; downloads a small ONNX model to
# ~/.cache/chroma on first use).
# LOON_MEMORY_BACKEND=sqlite

# --- Skills & masques ---
# Extra masque catalog searched after ./masques — a personas directory from
# https://github.com/ChrisDBaldwin/masques works as-is.
# LOON_MASQUES_DIR=/path/to/masques/personas
# Don a masque on the chat agent itself.
# LOON_MASQUE=analyst
# Context discipline for skill steps (approx tokens) + research fan-out.
# LOON_STEP_INPUT_BUDGET=4000
# LOON_STEP_MAX_TOKENS=3000
# LOON_RESEARCH_SOURCES=5

# --- Telegram adapter (python -m loon_agent telegram) ---
# Token from @BotFather.
# LOON_TELEGRAM_TOKEN=123456789:AA...
# Comma-separated numeric Telegram user ids allowed to talk to the bot.
# Empty = deny everyone; DM the bot once and it replies with your id.
# LOON_TELEGRAM_ALLOWED_USERS=123456789

# --- Web search (research skill): esper-search CLI on PATH, see docs/esper-search.md ---
# Read directly by the esper-search binary, not by loon's Settings.
# SEARXNG_URL=https://searxng.esper.internal
# SEARXNG_REDIS_URL=redis://:<VALKEY_PASSWORD>@192.168.0.114:6379/0
# SEARXNG_CA_BUNDLE=/path/to/esper-search/root.crt
# Override only if esper-search isn't on PATH:
# LOON_ESPER_SEARCH_BIN=/full/path/to/esper-search

# --- OpenTelemetry (optional; unset = no-op, set console to print spans) ---
# LOON_OTEL=console            # off | console | otlp
# OTEL_SERVICE_NAME=loon-agent
# :4317 = OTLP/gRPC, :4318 = OTLP/HTTP — the protocol is inferred from the port
# (override with OTEL_EXPORTER_OTLP_PROTOCOL=grpc|http/protobuf).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# gen_ai_latest_experimental is defaulted in code; override here if needed.
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
# Prompt/completion text is NOT recorded unless you opt in:
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
